# Firebase Admin → Firestore — backend 폴더 기준으로 JSON 경로 지정 (예시)
# GOOGLE_APPLICATION_CREDENTIALS=./프로젝트명-firebase-adminsdk-xxxxx.json
#
# 방법 B: JSON 전체를 한 줄 (따옴표 필수)
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

PREDICT_URL=http://localhost:8001
SENTIMENT_API_RETRY_COOLDOWN_MS=60000

# Daily close batch defaults (local dev recommended)
DAILY_JOB_CONCURRENCY=4
DAILY_JOB_SYMBOL_LIMIT=120

# After server start (once): backfill missing weekdays in last N calendar days per market TZ (today excluded).
# Creates analysis_daily + predictions like the scheduled job. Does not update job_meta.
STARTUP_CATCHUP_DAYS=7
# DISABLE_STARTUP_CATCHUP=1
ENABLE_STARTUP_CATCHUP=1
STARTUP_CATCHUP_SYMBOL_LIMIT=30
