# Firebase Admin → Firestore (아래 중 하나만 설정)
#
# 방법 A: 서비스 계정 JSON 파일 경로 (공식 문서와 동일한 방식)
# Firebase 콘솔 → 프로젝트 설정 → 서비스 계정 → 새 비공개 키 생성
# backend 기준 상대 경로 가능: ./serviceAccountKey.json
GOOGLE_APPLICATION_CREDENTIALS=/절대/경로/serviceAccountKey.json
# 또는
# FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./serviceAccountKey.json
#
# 방법 B: JSON 전체를 한 줄 문자열로 (따옴표 필수)
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...",...}'

PREDICT_URL=http://localhost:8001
