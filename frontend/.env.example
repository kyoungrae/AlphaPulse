# --- 프로덕션 빌드(`npm run build`)에만 의미 있음. `npm run dev`는 항상 로컬 프록시 사용 ---

# local = 상대 경로 /api (기본, 운영 API 추가 전과 동일)
# production = 아래 VITE_API_BASE_URL 로 요청
VITE_API_MODE=local

# 운영 모드일 때만 필수. 끝에 / 붙이지 않음
# VITE_API_BASE_URL=https://your-api.example.com

# --- Firebase (선택) — 비우면 코드에 있는 기본 프로젝트로 로컬·운영 모두 동일하게 연결 ---
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
